        "liquid_t4Er66": {
          "type": "liquid",
          "settings": {
            "liquid": "<style>\n  .urgency-block {\n    background: linear-gradient(135deg, #ff6b6b 0%, #ff8e72 100%);\n    border-radius: 12px;\n    padding: 18px 16px;\n    margin: 20px 0;\n    color: white;\n    font-weight: 600;\n    box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);\n    animation: pulse-glow 2s ease-in-out infinite;\n  }\n\n  @keyframes pulse-glow {\n    0%, 100% {\n      box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);\n    }\n    50% {\n      box-shadow: 0 4px 25px rgba(255, 107, 107, 0.5);\n    }\n  }\n\n  .urgency-message {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    margin-bottom: 14px;\n    font-size: 15px;\n    line-height: 1.5;\n    word-break: break-word;\n  }\n\n  .urgency-message:last-child {\n    margin-bottom: 0;\n  }\n\n  .urgency-icon {\n    font-size: 22px;\n    flex-shrink: 0;\n    animation: bounce 1s ease-in-out infinite;\n    display: inline-block;\n  }\n\n  .urgency-message:nth-child(2) .urgency-icon {\n    animation: pulse-icon 1s ease-in-out infinite;\n  }\n\n  @keyframes bounce {\n    0%, 100% {\n      transform: translateY(0);\n    }\n    50% {\n      transform: translateY(-3px);\n    }\n  }\n\n  @keyframes pulse-icon {\n    0%, 100% {\n      opacity: 1;\n    }\n    50% {\n      opacity: 0.7;\n    }\n  }\n\n  .visitor-count {\n    font-weight: 700;\n    display: inline-block;\n    min-width: 35px;\n    text-align: center;\n  }\n\n  .countdown-wrapper {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    flex-wrap: wrap;\n  }\n\n  .countdown {\n    font-weight: 700;\n    display: inline-block;\n    font-family: 'Courier New', monospace;\n    letter-spacing: 1px;\n    font-size: 18px;\n    background: rgba(255, 255, 255, 0.2);\n    padding: 6px 10px;\n    border-radius: 6px;\n    min-width: 120px;\n    text-align: center;\n  }\n\n  .countdown.expired {\n    color: rgba(255, 255, 255, 0.7);\n    opacity: 0.7;\n  }\n\n  /* Optimisation mobile */\n  @media (max-width: 768px) {\n    .urgency-block {\n      padding: 16px 14px;\n      margin: 16px 0;\n      border-radius: 10px;\n    }\n\n    .urgency-message {\n      font-size: 14px;\n      gap: 10px;\n      margin-bottom: 12px;\n    }\n\n    .urgency-icon {\n      font-size: 20px;\n      min-width: 24px;\n    }\n\n    .countdown {\n      font-size: 18px;\n      padding: 8px 12px;\n      min-width: 130px;\n    }\n  }\n\n  @media (max-width: 480px) {\n    .urgency-block {\n      padding: 14px 12px;\n      margin: 14px 0;\n    }\n\n    .urgency-message {\n      font-size: 13px;\n      gap: 8px;\n      margin-bottom: 10px;\n    }\n\n    .urgency-icon {\n      font-size: 18px;\n      min-width: 22px;\n    }\n\n    .countdown {\n      font-size: 16px;\n      padding: 6px 10px;\n      min-width: 110px;\n    }\n\n    .countdown-wrapper {\n      gap: 6px;\n    }\n  }\n</style>\n\n<div class=\"urgency-block\">\n  <div class=\"urgency-message\">\n    <span class=\"urgency-icon\">🔥</span>\n    <span><span class=\"visitor-count\" id=\"visitor-count\">12</span> personnes regardent ce produit</span>\n  </div>\n  <div class=\"urgency-message\">\n    <span class=\"urgency-icon\">⚡</span>\n    <div class=\"countdown-wrapper\">\n      <span>Commande dans les</span>\n      <span class=\"countdown\" id=\"countdown\">00:00:00</span>\n      <span>pour expédition aujourd'hui</span>\n    </div>\n  </div>\n</div>\n\n<script>\n  (function() {\n    'use strict';\n    \n    const DEADLINE_HOUR = 17;\n    const VISITOR_UPDATE_INTERVAL = 2500;\n    const COUNTDOWN_UPDATE_INTERVAL = 1000;\n\n    const visitorCountEl = document.getElementById('visitor-count');\n    const countdownEl = document.getElementById('countdown');\n\n    let currentVisitorCount = 12;\n    let countdownInterval = null;\n    let visitorInterval = null;\n\n    function getRandomInt(min, max) {\n      return Math.floor(Math.random() * (max - min + 1)) + min;\n    }\n\n    function updateVisitorCount() {\n      try {\n        const variation = getRandomInt(-2, 2);\n        currentVisitorCount = Math.max(8, Math.min(24, currentVisitorCount + variation));\n        \n        if (visitorCountEl && visitorCountEl.textContent !== undefined) {\n          visitorCountEl.textContent = currentVisitorCount;\n        }\n      } catch (e) {\n        console.error('Erreur mise à jour visiteurs:', e);\n      }\n    }\n\n    function getTimeUntilDeadline() {\n      try {\n        const now = new Date();\n        let deadline = new Date();\n        deadline.setHours(DEADLINE_HOUR, 0, 0, 0);\n\n        if (now > deadline) {\n          deadline.setDate(deadline.getDate() + 1);\n        }\n\n        const diff = deadline - now;\n        \n        if (diff <= 0) {\n          return { hours: 0, minutes: 0, seconds: 0, expired: true };\n        }\n\n        const hours = Math.floor(diff / (1000 * 60 * 60));\n        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));\n        const seconds = Math.floor((diff % (1000 * 60)) / 1000);\n\n        return { hours, minutes, seconds, expired: false };\n      } catch (e) {\n        console.error('Erreur calcul deadline:', e);\n        return { hours: 0, minutes: 0, seconds: 0, expired: true };\n      }\n    }\n\n    function formatTime(num) {\n      return String(num).padStart(2, '0');\n    }\n\n    function updateCountdown() {\n      try {\n        const time = getTimeUntilDeadline();\n        const timeString = `${formatTime(time.hours)}:${formatTime(time.minutes)}:${formatTime(time.seconds)}`;\n        \n        if (countdownEl && countdownEl.textContent !== undefined) {\n          countdownEl.textContent = timeString;\n          \n          if (time.expired) {\n            countdownEl.classList.add('expired');\n          } else {\n            countdownEl.classList.remove('expired');\n          }\n        }\n      } catch (e) {\n        console.error('Erreur mise à jour countdown:', e);\n      }\n    }\n\n    function startIntervals() {\n      try {\n        if (visitorCountEl) {\n          visitorInterval = setInterval(updateVisitorCount, VISITOR_UPDATE_INTERVAL);\n        }\n        if (countdownEl) {\n          countdownInterval = setInterval(updateCountdown, COUNTDOWN_UPDATE_INTERVAL);\n        }\n      } catch (e) {\n        console.error('Erreur démarrage intervalles:', e);\n      }\n    }\n\n    function init() {\n      try {\n        updateVisitorCount();\n        updateCountdown();\n        startIntervals();\n      } catch (e) {\n        console.error('Erreur initialisation:', e);\n      }\n    }\n\n    if (document.readyState === 'loading') {\n      document.addEventListener('DOMContentLoaded', init);\n    } else {\n      init();\n    }\n\n    window.addEventListener('beforeunload', function() {\n      if (countdownInterval) clearInterval(countdownInterval);\n      if (visitorInterval) clearInterval(visitorInterval);\n    });\n  })();\n</script>"
